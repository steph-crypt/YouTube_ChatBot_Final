# Anthropic — chat / answers (required)
ANTHROPIC_API_KEY=

# Optional Claude model id (see https://docs.anthropic.com/en/docs/about-claude/models/all-models)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Pinecone (required)
PINECONE_API_KEY=

# Index name after running scripts/reindex_pinecone.py (default matches below)
# PINECONE_INDEX_NAME=youtube-transcripts

# Local Hugging Face embedding model — must match what you used when re-indexing
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
